{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "particles.schema.json",
  "type": "array",
  "items": {
    "allOf": [
      {
        "$ref": "common.schema.json#/$defs/baseItem"
      },
      {
        "type": "object",
        "required": [
          "functions",
          "tone_effect"
        ],
        "properties": {
          "type": {
            "const": "particle"
          },
          "functions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "tone_effect": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    ],
    "unevaluatedProperties": false
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "expressions.schema.json",
  "type": "array",
  "items": {
    "allOf": [
      {
        "$ref": "common.schema.json#/$defs/baseItem"
      },
      {
        "type": "object",
        "required": [
          "register"
        ],
        "properties": {
          "type": {
            "const": "expression"
          },
          "register": {
            "enum": [
              "informal",
              "neutral",
              "formal"
            ]
          }
        }
      }
    ],
    "unevaluatedProperties": false
  }
}
